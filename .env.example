# ─── Supabase — Public (client-side, safe to expose) ───
# These NEXT_PUBLIC_* vars are visible to browser code.
# Get them from your Supabase project dashboard > Settings > API.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# ─── Hostinger Supabase wizard aliases ───
# Hostinger's deployment wizard sets SUPABASE_URL and SUPABASE_ANON_KEY.
# The app falls back to these if NEXT_PUBLIC_* are not set.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# ─── Supabase — Server-side only (never expose) ───
# Service role key bypasses RLS — only used in server functions (RPC route handler).
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─── ZATCA — Server-side only (never expose) ───
ZATCA_DEVICE_KEY_ENCRYPTION_SECRET="your-encryption-secret"
ZATCA_ENVIRONMENT="simulation"

# ─── Seed credentials (server-side only, for future seed script) ───
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_CASHIER_ASAD_PIN=
SEED_CASHIER_ABDULLAH_PIN=

# ─── Node.js runtime ───
NODE_ENV="production"
PORT="3000"
