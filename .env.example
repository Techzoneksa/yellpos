# ─── Supabase (client-side, safe to expose) ───
# These NEXT_PUBLIC_* vars are visible to browser code.
# Get them from your Supabase project dashboard > Settings > API.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# ─── Supabase (server-side only, never expose) ───
# Service role key bypasses RLS — only used in server functions (RPC route handler).
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─── ZATCA (server-side only, never expose) ───
# Encryption secret for the ZATCA device private key stored in the database.
ZATCA_DEVICE_KEY_ENCRYPTION_SECRET="your-encryption-secret"
# Set to "simulation" for testing; only change to "production" when ZATCA onboarded.
ZATCA_ENVIRONMENT="simulation"

# ─── Seed credentials for initial user setup (server-side only) ───
# Replace with secure values for local dev. Used by a future seed script
# to create initial Supabase Auth users. NEVER expose these to client code.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_CASHIER_ASAD_PIN=
SEED_CASHIER_ABDULLAH_PIN=

# ─── Node.js runtime ───
NODE_ENV="production"
# Hostinger provides PORT automatically; this fallback is for local testing.
PORT="3000"
