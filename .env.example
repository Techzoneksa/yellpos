# ─── Supabase — Public (browser-safe, inlined at build time) ───
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# ─── Supabase — Server-only (never exposed to browser) ───
# Legacy service_role JWT from Project Settings → API → Legacy keys
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-jwt"

# ─── Seed owner credentials (only used by /api/seed-owner) ───
# Set these to override defaults. Never set in production without protection.
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_OWNER_USERNAME=
SEED_OWNER_FULLNAME=

# ─── ZATCA — Server-only ───
ZATCA_DEVICE_KEY_ENCRYPTION_SECRET="your-encryption-secret"
ZATCA_ENVIRONMENT="simulation"

# ─── Runtime ───
NODE_ENV="production"
